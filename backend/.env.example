# Never commit backend/.env
# Put your real OpenRouter API key only in backend/.env

# OpenRouter LLM Provider (hosted, suitable for Hong Kong access)
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Pinned free models. Avoid openrouter/free (random routing -> unstable JSON).
# The hiring pipeline tries FREE_MODEL first, then the fallbacks in order.
OPENROUTER_FREE_MODEL=openai/gpt-oss-120b:free
OPENROUTER_FALLBACK_MODEL=openai/gpt-oss-20b:free
OPENROUTER_FALLBACK_MODEL_2=google/gemma-4-31b-it:free
APP_URL=http://localhost:5173
LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=3
# Per-request timeout (seconds). A stalled free-tier call fails after this
# instead of hanging the request forever.
LLM_TIMEOUT=120

# Bias-reduction hiring pipeline: how many resumes to score concurrently in
# scorecards/generate. Higher = faster, but free-tier models may rate-limit.
# Set to 1 to force sequential processing.
HIRING_MAX_CONCURRENCY=4
# On 429 rate-limit, retry the SAME (higher-quality) model with exponential
# backoff before failing over to a weaker fallback model.
LLM_RATE_LIMIT_RETRIES=4
LLM_RATE_LIMIT_BACKOFF=2.5

# ChromaDB Configuration
CHROMA_DB_PATH=./databases/chroma_moderation_db

# ============================================================================
# ML Model Configuration
# ============================================================================
USE_ML_MODELS=false
ML_PRIMARY_MODEL=distilbert_toxic
ML_USE_ENSEMBLE=false
ML_PRELOAD_MODELS=true
ML_DEVICE=auto
ML_MODELS_CACHE_DIR=./models_cache

# ============================================================================
# Quick Decision Check (formerly Fast Mode)
# ============================================================================
ENABLE_QUICK_DECISION_CHECK=true
QUICK_CHECK_MAX_LENGTH=300
QUICK_CHECK_DECISION_TYPES=quick_manager_note

# Legacy aliases (still supported)
ENABLE_FAST_MODE=true
FAST_MODE_MAX_LENGTH=300
FAST_MODE_CONTENT_TYPES=quick_manager_note
